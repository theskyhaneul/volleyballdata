# 로컬 개발: 이 파일을 복사해 .env 로 저장 (GitHub 업로드 금지)
#
# Supabase → Project Settings → Database → Connection string → URI
# [Copy] 로 복사한 "전체 문자열"을 그대로 붙여넣기 (xxxxx 예시 사용 금지)
#
# Direct connection 예 (사용자명 postgres):
# postgresql://postgres:비밀번호@db.프로젝트ID.supabase.co:5432/postgres
#
# Transaction pooler 예 (사용자명 postgres.프로젝트ID):
# postgresql://postgres.프로젝트ID:비밀번호@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

DATABASE_URL=

# pooler URL 에 사용자명이 postgres 만 있을 때 (선택)
SUPABASE_PROJECT_REF=your-project-ref-from-supabase-url

SECRET_KEY=local-dev-secret-change-me
SETUP_KEY=local-setup-key-only-for-dev
