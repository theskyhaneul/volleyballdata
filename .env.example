# 로컬: 복사 후 .env 로 저장 (GitHub 업로드 금지)

# ── 방법 1 (추천): 비밀번호에 # @ 가 있어도 안전 ──
SUPABASE_DB_HOST=db.xxxxxxxxxxxx.supabase.co
SUPABASE_DB_PASSWORD=여기에_데이터베이스_비밀번호_그대로
SUPABASE_DB_USER=postgres
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres

# pooler 사용 시만 (Direct connection 이면 비워두기)
# SUPABASE_PROJECT_REF=abcdefghijklmnop

# ── 방법 2: URI 한 줄 (Supabase Copy · # 없는 비밀번호에 적합) ──
# DATABASE_URL=postgresql://postgres:비밀번호@db.xxx.supabase.co:5432/postgres

SECRET_KEY=local-dev-secret-change-me
SETUP_KEY=local-setup-key-only-for-dev
